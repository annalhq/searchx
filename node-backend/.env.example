# Node.js backend environment
# Copy this to .env and fill in values after deploying the contract

# SearXNG instance URL
SEARXNG_URL=http://localhost:8080

# Hardhat local node RPC
RPC_URL=http://127.0.0.1:8545

# Hardhat default account #0 private key (DO NOT use in production)
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Deployed SearchVerifier contract address (updated by deploy script)
CONTRACT_ADDRESS=

# IPFS daemon URL (local IPFS Desktop or ipfs daemon)
IPFS_API_URL=http://127.0.0.1:5001

# Server port
PORT=3001
