vgUrl)\n          this.svgContent = await res.text()\n        } catch (e) {\n          console.warn('Failed to fetch favicon.svg:', e)\n          return\n        }\n      }\n      this.updateFavicon()\n    }\n\n    updateFavicon() {\n      const color = this.mediaQuery.matches ? '#ccc' : '#111'\n      if (this.currentColor === color) return\n      this.currentColor = color\n      this.updateFaviconColor(color)\n    }\n\n    updateFaviconColor(color) {\n      if (!this.svgContent) return\n      try {\n        const parser = new DOMParser()\n        const doc = parser.parseFromString(this.svgContent, 'image/svg+xml')\n\n        // Remove all <style> tags\n        doc.querySelectorAll('style').forEach((style) => style.remove())\n\n        // Recursively set fill attribute for all elements\n        function setFillRecursively(node) {\n          if (node.nodeType === 1) {\n            // Element node\n            node.setAttribute('fill', color)\n            // Remove fill from style attribute if present\n            if (node.hasAttribute('style')) {\n              let style = node.getAttribute('style')\n              style = style.replace(/fill\\s*:\\s*[^;]+;?/gi, '')\n              node.setAttribute('style', style)\n            }\n            for (let i = 0; i < node.childNodes.length; i++) {\n              setFillRecursively(node.childNodes[i])\n            }\n          }\n        }\n        setFillRecursively(doc.documentElement)\n\n        const serializer = new XMLSerializer()\n        const svg = serializer.serializeToString(doc)\n        const blob = new Blob([svg], { type: 'image/svg+xml' })\n        const blobUrl = URL.createObjectURL(blob)\n        this.faviconLink.href = blobUrl\n        if (this.previousBlobUrl) {\n          URL.revokeObjectURL(this.previousBlobUrl)\n        }\n        this.previousBlobUrl = blobUrl\n      } catch (e) {\n        console.warn('Failed to update favicon color:', e)\n      }\n    }\n  }\n\n  // Initialize favicon theme switcher\n  let faviconSwitcherInitialized = false\n  function init() {\n    if (faviconSwitcherInitialized) return\n    faviconSwitcherInitialized = true\n\n    try {\n      new FaviconThemeSwitcher()\n    } catch (error) {\n      console.warn('Failed to initialize favicon theme switcher:', error)\n    }\n  }\n\n  // Use only astro:page-load as it fires on initial load and navigation\n  document.addEventListener('astro:page-load', init)\n</script> <div class=\"layout-wrapper\" id=\"transition-wrapper\" data-astro-transition-scope=\"astro-3aq4ytkg-1\">    <div class=\"page-content\"> <div class=\"gradient-mask\" data-astro-cid-5gze4ep5>  </div> <script type=\"module\">let e=null,t=!1;function n(){if(e||(e=document.querySelector(\".gradient-mask\")),!e)return;window.scrollY>=64?e.style.opacity=\"1\":e.style.opacity=\"0\"}function o(){t||(t=!0,requestAnimationFrame(()=>{n(),t=!1}))}function r(){e=document.querySelector(\".gradient-mask\"),n()}document.addEventListener(\"astro:page-load\",r);window.addEventListener(\"scroll\",o,{passive:!0});</script>  <div> <header class=\"header\" data-astro-cid-qlfjksao> <nav class=\"nav\" data-astro-cid-qlfjksao> <div class=\"nav-left\" data-astro-cid-qlfjksao> <a href=\"/\" class=\"brand\" data-astro-cid-qlfjksao>annalhq</a> <a href=\"/space\" data-astro-cid-qlfjksao>space</a> <a href=\"/blogs\" data-astro-cid-qlfjksao>blogs</a> </div> <div class=\"nav-right\" data-astro-cid-qlfjksao> <button id=\"theme-toggle\" class=\"theme-toggle\" aria-label=\"Toggle theme\" data-astro-cid-lfoluaxz><div class=\"theme-icon hollow-circle\" data-astro-cid-lfoluaxz></div><div class=\"theme-icon solid-circle\" data-astro-cid-lfoluaxz></div></button><script>\n  function bindThemeToggle() {\n    const themeToggle = document.getElementById('theme-toggle')\n    if (!themeToggle || !window.ThemeManager) return\n\n    if (themeToggle.dataset.themeBound) return\n    themeToggle.dataset.themeBound = 'true'\n\n    themeToggle.addEventListener('click', function (e) {