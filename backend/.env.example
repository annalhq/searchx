# ── SearXNG ──────────────────────────────────────────────
SEARXNG_URL=http://localhost:8080

# ── Base Sepolia / Alchemy ────────────────────────────────
ALCHEMY_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY_HERE

# ── Wallet (used to sign blockchain transactions) ─────────
# WARNING: Never commit this file with a real private key!
WALLET_ADDRESS=0xYOUR_WALLET_ADDRESS
WALLET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# ── Smart Contract ────────────────────────────────────────
# Address of the deployed SearchX.sol on Base Sepolia
CONTRACT_ADDRESS=0xYOUR_CONTRACT_ADDRESS
